{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "connections_SCUS_Interconnect_Connection_Colo_name": {
            "defaultValue": "SCUS-Interconnect-Connection-Colo",
            "type": "String"
        },
        "virtualNetworkGateways_SCUS_Interconnect_VPNGW_externalid": {
            "defaultValue": "/subscriptions/13eb5256-bcb9-40a4-98ae-27f3f79e3a68/resourceGroups/Azure-Colo-Home-Interconnect/providers/Microsoft.Network/virtualNetworkGateways/SCUS-Interconnect-VPNGW",
            "type": "String"
        },
        "localNetworkGateways_SCUS_Interconnect_LNGW_Colo_externalid": {
            "defaultValue": "/subscriptions/13eb5256-bcb9-40a4-98ae-27f3f79e3a68/resourceGroups/Azure-Colo-Home-Interconnect/providers/Microsoft.Network/localNetworkGateways/SCUS-Interconnect-LNGW-Colo",
            "type": "String"
        }
    },
    "variables": {},
    "resources": [
        {
            "type": "Microsoft.Network/connections",
            "apiVersion": "2024-07-01",
            "name": "[parameters('connections_SCUS_Interconnect_Connection_Colo_name')]",
            "location": "southcentralus",
            "properties": {
                "virtualNetworkGateway1": {
                    "id": "[parameters('virtualNetworkGateways_SCUS_Interconnect_VPNGW_externalid')]",
                    "properties": {}
                },
                "localNetworkGateway2": {
                    "id": "[parameters('localNetworkGateways_SCUS_Interconnect_LNGW_Colo_externalid')]",
                    "properties": {}
                },
                "connectionType": "IPsec",
                "connectionProtocol": "IKEv2",
                "routingWeight": 0,
                "enableBgp": true,
                "useLocalAzureIpAddress": false,
                "usePolicyBasedTrafficSelectors": false,
                "ipsecPolicies": [
                    {
                        "saLifeTimeSeconds": 27000,
                        "saDataSizeKilobytes": 0,
                        "ipsecEncryption": "AES256",
                        "ipsecIntegrity": "SHA256",
                        "ikeEncryption": "AES256",
                        "ikeIntegrity": "SHA256",
                        "dhGroup": "DHGroup14",
                        "pfsGroup": "PFS2048"
                    }
                ],
                "trafficSelectorPolicies": [],
                "tunnelProperties": [],
                "expressRouteGatewayBypass": false,
                "enablePrivateLinkFastPath": false,
                "dpdTimeoutSeconds": 45,
                "connectionMode": "Default",
                "gatewayCustomBgpIpAddresses": [
                    {
                        "ipConfigurationId": "[concat(parameters('virtualNetworkGateways_SCUS_Interconnect_VPNGW_externalid'), '/ipConfigurations/default')]",
                        "customBgpIpAddress": "169.254.22.2"
                    }
                ]
            }
        }
    ]
}